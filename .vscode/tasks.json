{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build plugin zip",
      "type": "shell",
      "command": "chmod",
      "args": [
        "+x",
        "package-plugin.sh"
      ],
      "problemMatcher": []
    },
    {
      "label": "install git hooks",
      "type": "shell",
      "command": "chmod",
      "args": [
        "+x",
        "install-git-hooks.sh",
        ".githooks/pre-commit"
      ],
      "problemMatcher": []
    },
    {
      "label": "package plugin zip",
      "type": "shell",
      "command": "./package-plugin.sh",
      "dependsOn": "build plugin zip",
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "setup development hooks",
      "type": "shell",
      "command": "./install-git-hooks.sh",
      "dependsOn": "install git hooks",
      "problemMatcher": []
    },
    {
      "label": "lint php",
      "type": "shell",
      "command": "composer",
      "args": [
        "lint:php"
      ],
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "lint all",
      "type": "shell",
      "command": "composer",
      "args": [
        "lint"
      ],
      "problemMatcher": []
    },
    {
      "label": "fix php style",
      "type": "shell",
      "command": "vendor/bin/phpcbf",
      "args": [
        "--standard=phpcs.xml.dist"
      ],
      "problemMatcher": []
    },
    {
      "label": "plugin check",
      "type": "shell",
      "command": "wp",
      "args": [
        "--path=/srv/wordpress",
        "plugin",
        "check",
        "markdown-for-ai-agents",
        "--require=/srv/wordpress/wp-content/plugins/plugin-check/cli.php",
        "--exclude-directories=.devcontainer,.github,vendor,dist",
        "--exclude-files=.gitignore,install-git-hooks.sh,package-plugin.sh,phpcs.xml.dist,AGENTS.md"
      ],
      "problemMatcher": [],
      "group": "test"
    }
  ]
}